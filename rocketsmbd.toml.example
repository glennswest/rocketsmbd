# rocketsmbd example configuration
listen = "0.0.0.0:445"
workers = 0            # 0 = one worker per CPU core
server_name = "ROCKETSMBD"
log_level = 1          # 0 = warn, 1 = info, 2 = debug

# Performance tuning (sane defaults; usually leave as-is).
core_pinning = true    # pin worker N to core N (ring + softirqs + cache locality)
sqpoll = false         # kernel-thread SQ polling; only helps at high IOPS/many channels

# Security. With no [[user]] entries, guest access is allowed by default.
# Add users to require authentication; set allow_guest explicitly to override.
require_signing = false   # true = reject unsigned requests on auth'd sessions
encrypt = false          # true = require SMB3 encryption (AES-128-GCM)
# allow_guest = false

[[share]]
name = "data"
path = "/srv/data"
read_only = false

# Users (NTLMv2). Provide either a plaintext password or a precomputed
# NT hash (MD4 of the UTF-16LE password) as 32 hex characters.
# [[user]]
# name = "alice"
# password = "secret"
#
# [[user]]
# name = "bob"
# nt_hash = "8846f7eaee8fb117ad06bdd830b7586c"

# Experimental: grant Level II oplocks. OFF — cifs caches but ignores the
# legacy oplock-break (it wants a lease-break), so this can serve stale reads.
oplocks = false
